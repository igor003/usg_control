{% extends 'base.html.twig' %}

{% block title %}{{ page_title }} | Ultrasound Examination{% endblock %}

{% block stylesheets %}
    <style>
        .navbar-logo {
            width: 44px;
            height: 44px;
            object-fit: contain;
        }

        .controls-table th,
        .controls-table td {
            vertical-align: middle;
        }

        .control-order-input {
            width: 96px;
        }

        .control-order-input[readonly] {
            background: var(--bs-tertiary-bg);
        }
    </style>
{% endblock %}

{% block body %}
    {% include 'partials/_navbar.html.twig' %}

    <main class="container py-5">
        <div class="d-flex align-items-center justify-content-between gap-3 mb-4">
            <div>
                <h1 class="h4 mb-1">{{ page_title }}</h1>
                <p class="mb-0 text-secondary">{{ page_description }}</p>
            </div>
            <a class="btn btn-outline-secondary" href="{{ path('app_home') }}">Înapoi</a>
        </div>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success" role="alert">{{ message }}</div>
        {% endfor %}

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4 p-sm-5">
                {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}
                    {{ form_errors(form) }}

                    <div class="row g-3">
                        <div class="col-md-6">
                            {{ form_row(form.organ) }}
                        </div>
                        <div class="col-12">
                            <label class="form-label">Controale</label>
                            {% if parameters is empty %}
                                <p class="mb-0 text-secondary">Nu există parametri adăugați.</p>
                            {% else %}
                                {% set selected_parameter_ids = selected_parameter_orders|keys %}
                                <div class="table-responsive" data-control-order-list>
                                    <table class="table table-sm align-middle controls-table mb-0">
                                        <thead>
                                            <tr>
                                                <th>Activ</th>
                                                <th>Control</th>
                                                <th>Ordine</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% for parameter in parameters %}
                                                {% set is_selected = parameter.id in selected_parameter_ids %}
                                                <tr>
                                                    <td>
                                                        <input
                                                            class="form-check-input"
                                                            type="checkbox"
                                                            name="parameter_ids[]"
                                                            value="{{ parameter.id }}"
                                                            id="parameter_{{ parameter.id }}"
                                                            data-control-checkbox
                                                            {% if is_selected %}checked{% endif %}
                                                        >
                                                    </td>
                                                    <td>
                                                        <label class="form-check-label" for="parameter_{{ parameter.id }}">{{ parameter.name }}</label>
                                                    </td>
                                                    <td>
                                                        <input
                                                            class="form-control form-control-sm control-order-input"
                                                            type="number"
                                                            min="0"
                                                            step="1"
                                                            name="parameter_order[{{ parameter.id }}]"
                                                            data-control-order
                                                            data-parameter-id="{{ parameter.id }}"
                                                            value="{{ selected_parameter_orders[parameter.id] ?? loop.index }}"
                                                            readonly
                                                        >
                                                    </td>
                                                </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            {% endif %}
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <a class="btn btn-outline-secondary" href="{{ path('app_organ_controls_new') }}">Anulează</a>
                        {{ form_widget(form.save) }}
                    </div>
                {{ form_end(form) }}
            </div>
        </div>

        <div class="card border-0 shadow-sm mt-4">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
                    <div>
                        <h2 class="h5 mb-1">Legături adăugate</h2>
                        <p class="mb-0 text-secondary">Lista organelor și controalele asociate.</p>
                    </div>
                    <a class="btn btn-outline-primary" href="{{ path('app_organ_controls_new') }}">Legătură nouă</a>
                </div>

                {% if organs is empty %}
                    <p class="mb-0 text-secondary">Nu există organe adăugate.</p>
                {% else %}
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Organ</th>
                                    <th>Controale</th>
                                    <th class="text-end">Acțiuni</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for organ in organs %}
                                    <tr{% if editing_organ_id == organ.id %} class="table-primary"{% endif %}>
                                        <td class="fw-semibold">{{ organ.name }}</td>
                                        <td>
                                            {% if organ.organParameters is empty %}
                                                <span class="text-secondary">-</span>
                                            {% else %}
                                                {% for organParameter in organ.organParameters %}
                                                    {% if organParameter.parameter %}
                                                        <span class="badge text-bg-secondary me-1 mb-1">
                                                            {{ organParameter.sortOrder }}. {{ organParameter.parameter.name }}
                                                        </span>
                                                    {% endif %}
                                                {% endfor %}
                                            {% endif %}
                                        </td>
                                        <td class="text-end">
                                            <a class="btn btn-sm btn-outline-primary" href="{{ path('app_organ_controls_edit', { id: organ.id }) }}">Editează</a>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>
    </main>
{% endblock %}

{% block javascripts %}
    <script>
        document.querySelectorAll('[data-control-order-list]').forEach((container) => {
            const checkboxes = Array.from(container.querySelectorAll('[data-control-checkbox]'));
            const orderInputs = new Map(
                Array.from(container.querySelectorAll('[data-control-order]'))
                    .map((input) => [input.dataset.parameterId, input])
            );

            let selectedOrder = checkboxes
                .filter((checkbox) => checkbox.checked)
                .sort((left, right) => {
                    const leftOrder = Number(orderInputs.get(left.value)?.value || 0);
                    const rightOrder = Number(orderInputs.get(right.value)?.value || 0);

                    return leftOrder - rightOrder;
                })
                .map((checkbox) => checkbox.value);

            const syncOrders = () => {
                checkboxes.forEach((checkbox) => {
                    const input = orderInputs.get(checkbox.value);

                    if (!input) {
                        return;
                    }

                    const position = selectedOrder.indexOf(checkbox.value);

                    input.value = position === -1 ? '' : String(position + 1);
                });
            };

            checkboxes.forEach((checkbox) => {
                checkbox.addEventListener('change', () => {
                    selectedOrder = selectedOrder.filter((parameterId) => parameterId !== checkbox.value);

                    if (checkbox.checked) {
                        selectedOrder.push(checkbox.value);
                    }

                    syncOrders();
                });
            });

            syncOrders();
        });
    </script>
{% endblock %}
