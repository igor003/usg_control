{% extends 'base.html.twig' %}

{% block title %}Raport examinări | Ultrasound Examination{% endblock %}

{% block stylesheets %}
    <style>
        .navbar-logo {
            width: 44px;
            height: 44px;
            object-fit: contain;
        }

        .report-table {
            table-layout: fixed;
            width: 100%;
            font-size: .88rem;
            line-height: 1.25;
        }

        .report-table th,
        .report-table td {
            padding: .38rem .45rem;
            vertical-align: middle;
            overflow-wrap: anywhere;
        }

        .report-table .filter-row th {
            padding-top: .25rem;
            padding-bottom: .5rem;
            vertical-align: top;
        }

        .report-table .filter-row .form-control,
        .report-table .filter-row .form-select {
            width: 100%;
            min-width: 0;
            padding: .22rem .34rem;
            font-size: .82rem;
        }

        .report-table th:nth-child(1),
        .report-table td:nth-child(1) {
            width: 10%;
        }

        .report-table th:nth-child(2),
        .report-table td:nth-child(2) {
            width: 15%;
        }

        .report-table th:nth-child(3),
        .report-table td:nth-child(3) {
            width: 17%;
        }

        .report-table th:nth-child(4),
        .report-table td:nth-child(4) {
            width: 8%;
        }

        .report-table th:nth-child(5),
        .report-table td:nth-child(5) {
            width: 13%;
        }

        .report-table th:nth-child(6),
        .report-table td:nth-child(6) {
            width: 13%;
        }

        .report-table th:nth-child(7),
        .report-table td:nth-child(7) {
            width: 14%;
        }

        .report-table th:nth-child(8),
        .report-table td:nth-child(8) {
            width: 10%;
        }

        .report-cell-preview {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .report-period-actions {
            display: flex;
            align-items: end;
            height: 100%;
        }
    </style>
{% endblock %}

{% block body %}
    {% include 'partials/_navbar.html.twig' %}

    <main class="container-fluid px-2 px-xl-3 py-4">
        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
            <div>
                <h1 class="h4 mb-1">Raport examinări</h1>
                <p class="mb-0 text-secondary">Filtrați examinările salvate după orice coloană.</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a class="btn btn-success d-inline-flex align-items-center gap-2" href="{{ path('app_report_export') }}" data-report-export data-report-export-base="{{ path('app_report_export') }}">
                    <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="4" width="18" height="16" rx="2"></rect>
                        <path d="M3 10h18"></path>
                        <path d="M9 4v16"></path>
                        <path d="M15 4v16"></path>
                        <path d="M3 15h18"></path>
                    </svg>
                    <span>Export Excel</span>
                </a>
                <a class="btn btn-outline-secondary" href="{{ path('app_home') }}">Înapoi</a>
                <a class="btn btn-primary" href="{{ path('app_session_start') }}">Sesiune nouă</a>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-2 p-lg-3">
                {% if sessions is empty %}
                    <p class="mb-0 text-secondary">Nu există examinări salvate.</p>
                {% else %}
                    <div class="row g-3 align-items-end mb-3">
                        <div class="col-12 col-lg-4">
                            <label class="form-label" for="report_global_filter">Căutare generală</label>
                            <input class="form-control" id="report_global_filter" type="search" placeholder="Căutați în toate câmpurile" data-report-table-global>
                        </div>
                        <div class="col-12 col-sm-6 col-lg-2">
                            <label class="form-label" for="report_date_from">De la</label>
                            <input class="form-control" id="report_date_from" type="date" data-report-date-from>
                        </div>
                        <div class="col-12 col-sm-6 col-lg-2">
                            <label class="form-label" for="report_date_to">Până la</label>
                            <input class="form-control" id="report_date_to" type="date" data-report-date-to>
                        </div>
                        <div class="col-12 col-lg-auto">
                            <div class="report-period-actions">
                                <button class="btn btn-outline-secondary" type="button" data-report-date-clear>Resetează perioada</button>
                            </div>
                        </div>
                        <div class="col-12 col-lg-auto">
                            <div class="text-secondary" data-report-table-count></div>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-sm table-hover align-middle mb-0 report-table" data-report-table>
                            <thead>
                                <tr>
                                    <th>Data examinării</th>
                                    <th>Nume / Prenume pacient</th>
                                    <th>Tipul examinării</th>
                                    <th>Înlesniri</th>
                                    <th>Raion / Municipiu</th>
                                    <th>Localitatea</th>
                                    <th>Adresa</th>
                                    <th>Nr. telefon</th>
                                </tr>
                                <tr class="filter-row">
                                    <th><input class="form-control" type="search" aria-label="Filtru după data examinării" data-report-table-filter data-column="0"></th>
                                    <th><input class="form-control" type="search" aria-label="Filtru după nume și prenume" data-report-table-filter data-column="1"></th>
                                    <th><input class="form-control" type="search" aria-label="Filtru după tipul examinării" data-report-table-filter data-column="2"></th>
                                    <th>
                                        <select class="form-select" aria-label="Filtru după înlesniri" data-report-table-filter data-column="3">
                                            <option value="">Toate</option>
                                            <option value="Da">Da</option>
                                            <option value="Nu">Nu</option>
                                        </select>
                                    </th>
                                    <th><input class="form-control" type="search" aria-label="Filtru după raion sau municipiu" data-report-table-filter data-column="4"></th>
                                    <th><input class="form-control" type="search" aria-label="Filtru după localitate" data-report-table-filter data-column="5"></th>
                                    <th><input class="form-control" type="search" aria-label="Filtru după adresă" data-report-table-filter data-column="6"></th>
                                    <th><input class="form-control" type="search" aria-label="Filtru după telefon" data-report-table-filter data-column="7"></th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for session in sessions %}
                                    {% set patient = session.patient %}
                                    {% set city = patient ? patient.city : null %}
                                    {% set district = city ? city.district : null %}
                                    {% set selectedUltrasoundType = session.ultrasoundType %}
                                    {% set examinationTypes = [] %}
                                    {% for sessionOrgan in session.sessionOrgans %}
                                        {% set sideLabel = sessionOrgan.side == 'right' ? 'Dreapta' : (sessionOrgan.side == 'left' ? 'Stânga' : '') %}
                                        {% set examinationTypes = examinationTypes|merge([sessionOrgan.organName ~ (sideLabel ? ' - ' ~ sideLabel : '')]) %}
                                    {% endfor %}
                                    {% set examinationTypeLabel = selectedUltrasoundType ? selectedUltrasoundType.name : (examinationTypes|join(', ') ?: '-') %}
                                    {% set patientName = patient ? patient.lastName ~ ' ' ~ patient.firstName : '' %}
                                    {% set beneficiary = patient and patient.beneficiary ? 'Da' : 'Nu' %}
                                    {% set districtName = district ? district.name : '' %}
                                    {% set cityName = city ? city.name : '' %}
                                    {% set address = patient and patient.address ? patient.address : '' %}
                                    {% set phone = patient and patient.phone ? patient.phone : '' %}

                                    <tr data-report-row data-session-date="{{ session.sessionDate ? session.sessionDate|date('Y-m-d') : '' }}">
                                        <td data-filter-value="{{ session.sessionDate ? session.sessionDate|date('d.m.Y H:i') : '' }}">
                                            {{ session.sessionDate ? session.sessionDate|date('d.m.Y H:i') : '-' }}
                                        </td>
                                        <td data-filter-value="{{ patientName }}">
                                            <div class="fw-semibold">{{ patientName ?: '-' }}</div>
                                        </td>
                                        <td data-filter-value="{{ selectedUltrasoundType ? selectedUltrasoundType.name : examinationTypes|join(' ') }}">
                                            <div class="report-cell-preview">{{ examinationTypeLabel }}</div>
                                        </td>
                                        <td data-filter-value="{{ beneficiary }}">{{ beneficiary }}</td>
                                        <td data-filter-value="{{ districtName }}">{{ districtName ?: '-' }}</td>
                                        <td data-filter-value="{{ cityName }}">{{ cityName ?: '-' }}</td>
                                        <td data-filter-value="{{ address }}">
                                            <div class="report-cell-preview">{{ address ?: '-' }}</div>
                                        </td>
                                        <td data-filter-value="{{ phone }}">{{ phone ?: '-' }}</td>
                                    </tr>
                                {% endfor %}
                                <tr data-report-table-empty hidden>
                                    <td class="text-center text-secondary py-4" colspan="8">Nu au fost găsite examinări pentru filtrele selectate.</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>
    </main>
{% endblock %}

{% block javascripts %}
    <script>
        document.querySelectorAll('[data-report-table]').forEach((table) => {
            const globalFilter = document.querySelector('[data-report-table-global]');
            const dateFrom = document.querySelector('[data-report-date-from]');
            const dateTo = document.querySelector('[data-report-date-to]');
            const dateClear = document.querySelector('[data-report-date-clear]');
            const exportLink = document.querySelector('[data-report-export]');
            const filters = Array.from(document.querySelectorAll('[data-report-table-filter]'));
            const rows = Array.from(table.querySelectorAll('[data-report-row]'));
            const emptyRow = table.querySelector('[data-report-table-empty]');
            const count = document.querySelector('[data-report-table-count]');

            const normalizeValue = (value) => value
                .toString()
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '')
                .replace(/[șş]/g, 's')
                .replace(/[țţ]/g, 't')
                .toLowerCase()
                .trim();

            const getCellValue = (row, column) => {
                const cell = row.querySelectorAll('[data-filter-value]')[column];

                return cell ? cell.dataset.filterValue : '';
            };

            const updateCount = (visible) => {
                if (count) {
                    count.textContent = `${visible} din ${rows.length} examinări`;
                }
            };

            const updateExportUrl = () => {
                if (!exportLink) {
                    return;
                }

                const params = new URLSearchParams();

                if (globalFilter && globalFilter.value.trim() !== '') {
                    params.set('global', globalFilter.value.trim());
                }

                if (dateFrom && dateFrom.value !== '') {
                    params.set('date_from', dateFrom.value);
                }

                if (dateTo && dateTo.value !== '') {
                    params.set('date_to', dateTo.value);
                }

                filters.forEach((filter) => {
                    if (filter.value.trim() !== '') {
                        params.set(`column_${filter.dataset.column}`, filter.value.trim());
                    }
                });

                const query = params.toString();
                const baseUrl = exportLink.dataset.reportExportBase || exportLink.href;
                exportLink.href = query === '' ? baseUrl : `${baseUrl}?${query}`;
            };

            const applyFilters = () => {
                const globalTerm = normalizeValue(globalFilter ? globalFilter.value : '');
                const dateFromValue = dateFrom ? dateFrom.value : '';
                const dateToValue = dateTo ? dateTo.value : '';
                let visible = 0;

                rows.forEach((row) => {
                    const rowDate = row.dataset.sessionDate || '';
                    const rowText = normalizeValue(
                        Array.from(row.querySelectorAll('[data-filter-value]'))
                            .map((cell) => cell.dataset.filterValue)
                            .join(' ')
                    );
                    const matchesGlobal = globalTerm === '' || rowText.includes(globalTerm);
                    const matchesColumns = filters.every((filter) => {
                        const term = normalizeValue(filter.value);

                        if (term === '') {
                            return true;
                        }

                        return normalizeValue(getCellValue(row, Number(filter.dataset.column))).includes(term);
                    });
                    const matchesDateFrom = dateFromValue === '' || (rowDate !== '' && rowDate >= dateFromValue);
                    const matchesDateTo = dateToValue === '' || (rowDate !== '' && rowDate <= dateToValue);
                    const isVisible = matchesGlobal && matchesColumns && matchesDateFrom && matchesDateTo;

                    row.hidden = !isVisible;

                    if (isVisible) {
                        visible += 1;
                    }
                });

                if (emptyRow) {
                    emptyRow.hidden = visible !== 0;
                }

                updateCount(visible);
                updateExportUrl();
            };

            if (globalFilter) {
                globalFilter.addEventListener('input', applyFilters);
            }

            if (dateFrom) {
                dateFrom.addEventListener('input', applyFilters);
                dateFrom.addEventListener('change', applyFilters);
            }

            if (dateTo) {
                dateTo.addEventListener('input', applyFilters);
                dateTo.addEventListener('change', applyFilters);
            }

            if (dateClear) {
                dateClear.addEventListener('click', () => {
                    if (dateFrom) {
                        dateFrom.value = '';
                    }

                    if (dateTo) {
                        dateTo.value = '';
                    }

                    applyFilters();
                });
            }

            filters.forEach((filter) => {
                filter.addEventListener('input', applyFilters);
                filter.addEventListener('change', applyFilters);
            });

            applyFilters();
        });
    </script>
{% endblock %}
