{% extends 'base.html.twig' %}

{% block title %}{{ page_title }} | Ultrasound Examination{% endblock %}

{% block stylesheets %}
    <style>
        .navbar-logo {
            width: 44px;
            height: 44px;
            object-fit: contain;
        }

        .live-search {
            position: relative;
        }

        .live-search-results {
            position: absolute;
            z-index: 20;
            top: calc(100% + 2px);
            left: 0;
            right: 0;
            max-height: 260px;
            overflow-y: auto;
        }

        .live-search-option {
            text-align: left;
        }
    </style>
{% endblock %}

{% block body %}
    {% include 'partials/_navbar.html.twig' %}

    <main class="container py-5">
        <div class="d-flex align-items-center justify-content-between gap-3 mb-4">
            <div>
                <h1 class="h4 mb-1">{{ page_title }}</h1>
                <p class="mb-0 text-secondary">{{ page_description }}</p>
            </div>
            <a class="btn btn-outline-secondary" href="{{ path('app_patients_index') }}">Lista pacienților</a>
            <a class="btn btn-outline-secondary" href="{{ path('app_home') }}">Înapoi</a>
        </div>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success" role="alert">{{ message }}</div>
        {% endfor %}

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4 p-sm-5">
                {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}
                    {{ form_errors(form) }}

                    <div class="row g-3">
                        <div class="col-md-6">
                            {{ form_row(form.firstName) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.lastName) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.gender) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.birthYear) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.phone) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.idnp) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.seria) }}
                        </div>
                        <div class="col-md-6">
                            {% set selectedCity = form.vars.data.city %}
                            <div class="mb-3 live-search" data-city-search data-city-search-url="{{ path('app_cities_search') }}">
                                <label class="form-label" for="patients_city_search">Localitatea</label>
                                <input
                                    class="form-control"
                                    id="patients_city_search"
                                    type="text"
                                    autocomplete="off"
                                    placeholder="Începeți să tastați localitatea"
                                    value="{% if selectedCity %}{{ selectedCity.district.name }} - {{ selectedCity.name }}{% endif %}"
                                    data-city-search-input
                                >
                                {{ form_widget(form.city, { attr: { 'data-city-search-value': '' } }) }}
                                <div class="list-group shadow-sm live-search-results" data-city-search-results hidden></div>
                                {{ form_errors(form.city) }}
                            </div>
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.address) }}
                        </div>
                        <div class="col-12">
                            {{ form_row(form.beneficiary) }}
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <a class="btn btn-outline-secondary" href="{{ path('app_patients_new') }}">Anulează</a>
                        {{ form_widget(form.save) }}
                    </div>
                {{ form_end(form) }}
            </div>
        </div>

