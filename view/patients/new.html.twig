{% block javascripts %}
    <script>
        document.querySelectorAll('[data-city-search]').forEach((container) => {
            const url = container.dataset.citySearchUrl;
            const input = container.querySelector('[data-city-search-input]');
            const valueInput = container.querySelector('[data-city-search-value]');
            const results = container.querySelector('[data-city-search-results]');
            let controller = null;
            let timer = null;

            const closeResults = () => {
                results.hidden = true;
                results.innerHTML = '';
            };

            const renderResults = (items) => {
                results.innerHTML = '';

                if (items.length === 0) {
                    const empty = document.createElement('div');
                    empty.className = 'list-group-item text-secondary';
                    empty.textContent = 'Nu au fost găsite localități.';
                    results.appendChild(empty);
                    results.hidden = false;
                    return;
                }

                items.forEach((item) => {
                    const option = document.createElement('button');
                    option.type = 'button';
                    option.className = 'list-group-item list-group-item-action live-search-option';
                    option.textContent = item.label;
                    option.addEventListener('click', () => {
                        input.value = item.label;
                        valueInput.value = item.id;
                        closeResults();
                    });
                    results.appendChild(option);
                });

                results.hidden = false;
            };

            input.addEventListener('input', () => {
                valueInput.value = '';
                window.clearTimeout(timer);

                const query = input.value.trim();

                if (query.length < 2) {
                    closeResults();
                    return;
                }

                timer = window.setTimeout(() => {
                    if (controller !== null) {
                        controller.abort();
                    }

                    controller = new AbortController();

                    fetch(`${url}?q=${encodeURIComponent(query)}`, {
                        headers: { Accept: 'application/json' },
                        signal: controller.signal,
                    })
                        .then((response) => response.ok ? response.json() : [])
                        .then(renderResults)
                        .catch((error) => {
                            if (error.name !== 'AbortError') {
                                closeResults();
                            }
                        });
                }, 200);
            });

            input.addEventListener('keydown', (event) => {
                if (event.key === 'Escape') {
                    closeResults();
                }
            });

            document.addEventListener('click', (event) => {
                if (!container.contains(event.target)) {
                    closeResults();
                }
            });
        });
    </script>
{% endblock %}
